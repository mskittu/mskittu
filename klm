SELECT 
    SUM(WRITE_OFF) AS SUM_WRITE_OFF,
    SUM(ASCII(DLNQT_CD)) AS SUM_DLNQT_CD,
    SUM(ASCII(HRAM_FLAG)) AS SUM_HRAM_FLAG
FROM usrf_pub_rft_mdl.FIN_MDS_FACT_MTD_C
WHERE PTN_VAL_TXT = '20260131'
  AND "BD4" = 'Impairment BTB';



SELECT 
    COUNT(*) AS TOTAL_ROWS,
    SUM(WRITE_OFF) AS SUM_WRITE_OFF,
    COUNT(DLNQT_CD) AS DLNQT_CD_NOT_NULL,
    SUM(ASCII(DLNQT_CD)) AS SUM_DLNQT_CD,
    COUNT(HRAM_FLAG) AS HRAM_FLAG_NOT_NULL,
    SUM(ASCII(HRAM_FLAG)) AS SUM_HRAM_FLAG
FROM usrf_pub_rft_mdl.FIN_MDS_FACT_MTD_C
WHERE PTN_VAL_TXT = '20260131'
  AND "BD4" = 'Impairment BTB';



SELECT 
CASE WHEN SUM(WRITE_OFF) > 0 THEN 'PASS' ELSE 'FAIL' END AS WRITE_OFF_STATUS,
CASE WHEN SUM(ASCII(DLNQT_CD)) > 0 THEN 'PASS' ELSE 'FAIL' END AS DLNQT_STATUS,
CASE WHEN SUM(ASCII(HRAM_FLAG)) > 0 THEN 'PASS' ELSE 'FAIL' END AS HRAM_STATUS
FROM usrf_pub_rft_mdl.FIN_MDS_FACT_MTD_C
WHERE PTN_VAL_TXT = '20260131'
  AND "BD4" = 'Impairment BTB';

