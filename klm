#!/bin/bash

###############################################################################
# Script Name : aws_qa_p2pqa_p2pdev_s3_migration.sh
# Flow        : AWS QA -> P2P QA -> P2P DEV -> AWS DEV
# Description :
#   1. Login to P2P QA
#   2. Copy source partition data from AWS QA S3 to P2P QA temp directory
#   3. Create tar.gz in P2P QA
#   4. Transfer tar.gz from P2P QA to P2P DEV
#   5. Login to P2P DEV
#   6. Untar files in P2P DEV
#   7. Sync files from P2P DEV to AWS DEV S3
#   8. Run MSCK REPAIR TABLE
###############################################################################

set -euo pipefail

###############################################################################
# USAGE
###############################################################################
usage() {
  echo "Usage: $0 <source_s3_loc> <table_name> <partition_name> <target_s3_loc>"
  echo
  echo "Example:"
  echo "  $0 s3://qa-bucket/base_path customer_table partition_date=20260327 s3://dev-bucket/base_path"
  exit 1
}

if [ "$#" -ne 4 ]; then
  usage
fi

###############################################################################
# INPUT PARAMETERS
###############################################################################
SRC_S3_LOC="$1"
TABLE_NAME="$2"
PARTITION_NAME="$3"
TGT_S3_LOC="$4"

###############################################################################
# CONFIGURATION
###############################################################################
P2P_QA_HOST="your_user@qa-server.intranet.barcapint.com"
P2P_DEV_HOST="your_user@dev-server.intranet.barcapint.com"

PROFILE_FILE='/apps/data_abinitio/RFUW/abinitio_RFUW_DISK/'"$(whoami)"'/uscbrft_services/dataTransferServices/access/.cliv3_access_bash_profile'

# Password files
# Keep permission as chmod 600
QA_PASSWORD_FILE="/path/to/qa_password_file"
DEV_PASSWORD_FILE="/path/to/dev_password_file"

RUN_ID="$(date +%Y%m%d%H%M%S)_$$"
QA_BASE_DIR="/tmp/${TABLE_NAME}_${PARTITION_NAME}_${RUN_ID}"
QA_DATA_DIR="${QA_BASE_DIR}/data"
QA_TAR_FILE="/tmp/${TABLE_NAME}_${PARTITION_NAME}_${RUN_ID}.tar.gz"

DEV_BASE_DIR="/tmp/${TABLE_NAME}_${PARTITION_NAME}_${RUN_ID}"
DEV_DATA_DIR="${DEV_BASE_DIR}/data"

LOG_FILE="/tmp/${TABLE_NAME}_${PARTITION_NAME}_${RUN_ID}.log"

###############################################################################
# LOGGING
###############################################################################
log() {
  echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" | tee -a "$LOG_FILE"
}

###############################################################################
# VALIDATIONS
###############################################################################
validate_file() {
  local file_path="$1"
  local file_desc="$2"

  if [ ! -f "$file_path" ]; then
    log "ERROR: $file_desc not found: $file_path"
    exit 1
  fi
}

validate_file "$QA_PASSWORD_FILE" "QA password file"
validate_file "$DEV_PASSWORD_FILE" "DEV password file"

###############################################################################
# START
###############################################################################
log "Script started"
log "Source S3      : $SRC_S3_LOC"
log "Table Name     : $TABLE_NAME"
log "Partition Name : $PARTITION_NAME"
log "Target S3      : $TGT_S3_LOC"
log "P2P QA Host    : $P2P_QA_HOST"
log "P2P DEV Host   : $P2P_DEV_HOST"

###############################################################################
# STEP 1: EXECUTE IN P2P QA
###############################################################################
log "Starting operations in P2P QA"

sshpass -f "$QA_PASSWORD_FILE" ssh -o StrictHostKeyChecking=no "$P2P_QA_HOST" bash <<EOF
set -euo pipefail

SRC_S3_LOC="$SRC_S3_LOC"
TABLE_NAME="$TABLE_NAME"
PARTITION_NAME="$PARTITION_NAME"
QA_BASE_DIR="$QA_BASE_DIR"
QA_DATA_DIR="$QA_DATA_DIR"
QA_TAR_FILE="$QA_TAR_FILE"
PROFILE_FILE="$PROFILE_FILE"
P2P_DEV_HOST="$P2P_DEV_HOST"
DEV_PASSWORD_FILE="$DEV_PASSWORD_FILE"

echo "[\$(date '+%Y-%m-%d %H:%M:%S')] Connected to P2P QA"

if [ -f "\$PROFILE_FILE" ]; then
  source "\$PROFILE_FILE"
fi

echo "[\$(date '+%Y-%m-%d %H:%M:%S')] Cleaning old QA temp path if exists"
rm -rf "\$QA_BASE_DIR"
mkdir -p "\$QA_DATA_DIR"

echo "[\$(date '+%Y-%m-%d %H:%M:%S')] Copying data from AWS QA S3"
aws s3 cp "\${SRC_S3_LOC}/\${TABLE_NAME}/\${PARTITION_NAME}/" "\$QA_DATA_DIR/" --recursive

QA_FILE_COUNT=\$(find "\$QA_DATA_DIR" -type f | wc -l | tr -d ' ')
if [ "\$QA_FILE_COUNT" -eq 0 ]; then
  echo "[\$(date '+%Y-%m-%d %H:%M:%S')] ERROR: No files copied from source S3 in QA"
  exit 1
fi

echo "[\$(date '+%Y-%m-%d %H:%M:%S')] Files copied in QA: \$QA_FILE_COUNT"

echo "[\$(date '+%Y-%m-%d %H:%M:%S')] Creating tar.gz in QA"
tar -czf "\$QA_TAR_FILE" -C "\$QA_BASE_DIR" data

if [ ! -f "\$QA_TAR_FILE" ]; then
  echo "[\$(date '+%Y-%m-%d %H:%M:%S')] ERROR: Tar file not created in QA"
  exit 1
fi

echo "[\$(date '+%Y-%m-%d %H:%M:%S')] Transferring tar.gz from P2P QA to P2P DEV"
sshpass -f "\$DEV_PASSWORD_FILE" scp -o StrictHostKeyChecking=no "\$QA_TAR_FILE" "\${P2P_DEV_HOST}:/tmp/"

echo "[\$(date '+%Y-%m-%d %H:%M:%S')] QA step completed"
EOF

log "P2P QA operations completed"

###############################################################################
# STEP 2: EXECUTE IN P2P DEV
###############################################################################
log "Starting operations in P2P DEV"

sshpass -f "$DEV_PASSWORD_FILE" ssh -o StrictHostKeyChecking=no "$P2P_DEV_HOST" bash <<EOF
set -euo pipefail

TABLE_NAME="$TABLE_NAME"
PARTITION_NAME="$PARTITION_NAME"
TGT_S3_LOC="$TGT_S3_LOC"
DEV_BASE_DIR="$DEV_BASE_DIR"
DEV_DATA_DIR="$DEV_DATA_DIR"
QA_TAR_FILE="$QA_TAR_FILE"
QA_TAR_BASENAME="\$(basename "$QA_TAR_FILE")"
PROFILE_FILE="$PROFILE_FILE"

echo "[\$(date '+%Y-%m-%d %H:%M:%S')] Connected to P2P DEV"

if [ -f "\$PROFILE_FILE" ]; then
  source "\$PROFILE_FILE"
fi

echo "[\$(date '+%Y-%m-%d %H:%M:%S')] Cleaning old DEV temp path if exists"
rm -rf "\$DEV_BASE_DIR"
mkdir -p "\$DEV_BASE_DIR"

echo "[\$(date '+%Y-%m-%d %H:%M:%S')] Extracting tar.gz in DEV"
tar -xzf "/tmp/\$QA_TAR_BASENAME" -C "\$DEV_BASE_DIR"

DEV_FILE_COUNT=\$(find "\$DEV_DATA_DIR" -type f | wc -l | tr -d ' ')
if [ "\$DEV_FILE_COUNT" -eq 0 ]; then
  echo "[\$(date '+%Y-%m-%d %H:%M:%S')] ERROR: No files found after untar in DEV"
  exit 1
fi

echo "[\$(date '+%Y-%m-%d %H:%M:%S')] Files available in DEV: \$DEV_FILE_COUNT"

echo "[\$(date '+%Y-%m-%d %H:%M:%S')] Syncing data to AWS DEV S3"
aws s3 sync "\$DEV_DATA_DIR/" "\${TGT_S3_LOC}/\${TABLE_NAME}/\${PARTITION_NAME}/"

echo "[\$(date '+%Y-%m-%d %H:%M:%S')] Running MSCK REPAIR TABLE"
hive -e "MSCK REPAIR TABLE \${TABLE_NAME};"

echo "[\$(date '+%Y-%m-%d %H:%M:%S')] Cleaning DEV temp files"
rm -rf "\$DEV_BASE_DIR"
rm -f "/tmp/\$QA_TAR_BASENAME"

echo "[\$(date '+%Y-%m-%d %H:%M:%S')] DEV step completed"
EOF

log "P2P DEV operations completed"

###############################################################################
# STEP 3: CLEANUP IN P2P QA
###############################################################################
log "Cleaning tar/temp files in P2P QA"

sshpass -f "$QA_PASSWORD_FILE" ssh -o StrictHostKeyChecking=no "$P2P_QA_HOST" bash <<EOF
set -euo pipefail
rm -rf "$QA_BASE_DIR"
rm -f "$QA_TAR_FILE"
EOF

log "Cleanup completed in P2P QA"

###############################################################################
# COMPLETE
###############################################################################
log "Data migration completed successfully"
log "Log file: $LOG_FILE"
