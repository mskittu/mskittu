#!/usr/bin/env python3

import argparse
import logging
from urllib.parse import urlparse

import boto3
from botocore.exceptions import ClientError


# ------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------
logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s | %(levelname)s | %(message)s"
)
logger = logging.getLogger(__name__)


# ------------------------------------------------------------------------------
# Helpers
# ------------------------------------------------------------------------------
def parse_s3_path(s3_path: str):
    """Split S3 path into bucket and prefix."""
    if not s3_path.startswith("s3://"):
        raise ValueError(f"Invalid S3 path: {s3_path}")

    parsed = urlparse(s3_path)
    bucket = parsed.netloc
    prefix = parsed.path.lstrip("/")

    return bucket, prefix


def get_s3_client(profile_name: str):
    """Create S3 client using AWS profile."""
    session = boto3.Session(profile_name=profile_name)
    return session.client("s3")


def list_s3_objects(s3_client, bucket, prefix):
    """List all objects under prefix."""
    paginator = s3_client.get_paginator("list_objects_v2")
    keys = []

    for page in paginator.paginate(Bucket=bucket, Prefix=prefix):
        for obj in page.get("Contents", []):
            key = obj["Key"]
            if not key.endswith("/"):
                keys.append(key)

    return keys


# ------------------------------------------------------------------------------
# Main Copy Logic
# ------------------------------------------------------------------------------
def copy_s3_to_s3(source_s3, target_s3, source_profile, target_profile):
    """
    Copy data from source S3 (UAT) to target S3 (DEV)
    """

    src_bucket, src_prefix = parse_s3_path(source_s3)
    tgt_bucket, tgt_prefix = parse_s3_path(target_s3)

    # Source client (UAT)
    src_client = get_s3_client(source_profile)

    # Target client (DEV)
    tgt_client = get_s3_client(target_profile)

    logger.info("Listing objects from source: %s", source_s3)
    object_keys = list_s3_objects(src_client, src_bucket, src_prefix)

    if not object_keys:
        logger.warning("No files found in source path")
        return

    logger.info("Total files found: %d", len(object_keys))

    for key in object_keys:
        # Maintain folder structure
        relative_path = key[len(src_prefix):] if src_prefix else key
        target_key = f"{tgt_prefix.rstrip('/')}/{relative_path}".lstrip("/")

        copy_source = {
            "Bucket": src_bucket,
            "Key": key
        }

        try:
            logger.info(
                "Copying s3://%s/%s -> s3://%s/%s",
                src_bucket, key, tgt_bucket, target_key
            )

            tgt_client.copy(
                copy_source,
                tgt_bucket,
                target_key
            )

        except ClientError as e:
            logger.error("Failed to copy %s: %s", key, str(e))

    logger.info("S3 to S3 copy completed successfully")


# ------------------------------------------------------------------------------
# Entry Point
# ------------------------------------------------------------------------------
def main():
    parser = argparse.ArgumentParser(
        description="Copy data from UAT S3 to DEV S3 (cross-account)"
    )

    parser.add_argument("source_s3_path", help="Source S3 path (UAT)")
    parser.add_argument("target_s3_path", help="Target S3 path (DEV)")

    args = parser.parse_args()

    # Read profiles from environment
    import os
    source_profile = os.getenv("SOURCE_AWS_PROFILE")
    target_profile = os.getenv("TARGET_AWS_PROFILE")

    if not source_profile or not target_profile:
        raise ValueError("Set SOURCE_AWS_PROFILE and TARGET_AWS_PROFILE")

    copy_s3_to_s3(
        args.source_s3_path,
        args.target_s3_path,
        source_profile,
        target_profile
    )


if __name__ == "__main__":
    main()
