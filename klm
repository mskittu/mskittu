#!/bin/bash

#########################################
# Script Name : data_migration.sh
# Description : AWS QA → P2P QA → P2P DEV → AWS DEV
#########################################

set -e  # Exit on error

##############################
# INPUT PARAMETERS
##############################
SRC_S3_LOC=$1
TABLE_NAME=$2
PARTITION_NAME=$3
TGT_S3_LOC=$4

##############################
# VARIABLES
##############################
TMP_DIR="/tmp/${TABLE_NAME}_${PARTITION_NAME}"
TAR_FILE="${TABLE_NAME}_${PARTITION_NAME}.tar.gz"
P2P_DEV_HOST="sysPrtgQArfuwcrnat@nykdsr000007625.intranet.barcapint.com"
PASSWORD_FILE="/path/to/password_file"   # secure this properly

##############################
# STEP 1: CREATE TEMP DIR
##############################
echo "Creating temp directory..."
mkdir -p ${TMP_DIR}

##############################
# STEP 2: COPY FROM S3 (QA)
##############################
echo "Copying data from S3..."
aws s3 cp ${SRC_S3_LOC}/${TABLE_NAME}/${PARTITION_NAME}/ ${TMP_DIR}/ --recursive

##############################
# STEP 3: CREATE TAR
##############################
echo "Creating tar file..."
cd /tmp
tar -czvf ${TAR_FILE} ${TABLE_NAME}_${PARTITION_NAME}

##############################
# STEP 4: SFTP TO P2P DEV
##############################
echo "Transferring file to P2P DEV..."

sftp -oBatchMode=no -b - ${P2P_DEV_HOST} <<EOF
put /tmp/${TAR_FILE} /tmp/
bye
EOF

##############################
# STEP 5: REMOTE EXECUTION (UNTAR + S3 SYNC)
##############################
echo "Executing remote commands on P2P DEV..."

ssh ${P2P_DEV_HOST} <<EOF

echo "Untarring file..."
cd /tmp
tar -xzvf ${TAR_FILE}

echo "Syncing data to target S3..."
aws s3 sync /tmp/${TABLE_NAME}_${PARTITION_NAME}/ ${TGT_S3_LOC}/${TABLE_NAME}/${PARTITION_NAME}/

echo "Running MSCK REPAIR..."
hive -e "MSCK REPAIR TABLE ${TABLE_NAME};"

EOF

##############################
# STEP 6: CLEANUP
##############################
echo "Cleaning up..."
rm -rf ${TMP_DIR}
rm -f /tmp/${TAR_FILE}

echo "✅ Data migration completed successfully!"
